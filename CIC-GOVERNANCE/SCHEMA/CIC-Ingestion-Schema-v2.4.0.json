{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:cic:ingestion-schema:2.4.0",
  "title": "CIC Ingestion Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_id", "artifact_version", "spec_version", "source_hash", "actor", "action", "payload", "timestamp"],
  "properties": {
    "artifact_id": {"type": "string", "pattern": "^ART-[0-9]{8}-[0-9]{4}$"},
    "artifact_version": {"type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"},
    "spec_version": {"const": "2.4.0"},
    "source_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "actor": {"type": "string", "minLength": 1},
    "action": {"enum": ["INGEST", "UPDATE", "DEPRECATE", "RETIRE"]},
    "payload": {"type": "object"},
    "timestamp": {"type": "string", "format": "date-time"},
    "parent_artifact_id": {"type": ["string", "null"], "pattern": "^ART-[0-9]{8}-[0-9]{4}$"},
    "tags": {"type": "array", "maxItems": 10, "items": {"type": "string"}},
    "notes": {"type": "string", "maxLength": 1000}
  },
  "allOf": [
    {
      "if": {"properties": {"action": {"const": "DEPRECATE"}}},
      "then": {"required": ["parent_artifact_id"], "properties": {"parent_artifact_id": {"type": "string"}}}
    }
  ]
}
