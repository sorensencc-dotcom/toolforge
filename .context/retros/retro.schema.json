{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Session Retro Schema",
  "description": "Mandatory schema for .context/retros/*.json files",
  "type": "object",
  "required": [
    "date",
    "window",
    "since",
    "user",
    "metrics",
    "key_achievements"
  ],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Session date in YYYY-MM-DD format"
    },
    "window": {
      "type": "string",
      "enum": ["1d", "3d", "7d", "30d"],
      "description": "Lookback window"
    },
    "since": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp for window start"
    },
    "user": {
      "type": "string",
      "description": "User/session owner"
    },
    "metrics": {
      "type": "object",
      "required": [
        "commits_human",
        "commits_bot",
        "contributors",
        "insertions",
        "deletions",
        "net_loc",
        "test_loc",
        "test_ratio_pct",
        "active_days",
        "sessions_detected",
        "avg_session_minutes",
        "commits_per_day"
      ],
      "properties": {
        "commits_human": { "type": "number" },
        "commits_bot": { "type": "number" },
        "contributors": { "type": "number" },
        "insertions": { "type": "number" },
        "deletions": { "type": "number" },
        "net_loc": { "type": "number" },
        "test_loc": { "type": "number" },
        "test_ratio_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "active_days": { "type": "number" },
        "sessions_detected": { "type": "number" },
        "avg_session_minutes": { "type": "number" },
        "commits_per_day": { "type": "number" }
      }
    },
    "commit_breakdown": {
      "type": "object",
      "required": ["feat", "fix", "refactor", "chore", "docs", "other"],
      "properties": {
        "feat": { "type": "number" },
        "fix": { "type": "number" },
        "refactor": { "type": "number" },
        "chore": { "type": "number" },
        "docs": { "type": "number" },
        "other": { "type": "number" }
      }
    },
    "version_range": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "string" },
      "description": "Semantic version range [min, max]"
    },
    "peak_hours": {
      "type": "array",
      "items": { "type": "number", "minimum": 0, "maximum": 23 },
      "description": "Hours of peak activity (0-23)"
    },
    "project_focus": {
      "type": "string",
      "description": "Primary project or initiative"
    },
    "key_achievements": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "List of accomplishments"
    },
    "critical_findings_fixed": {
      "type": "number",
      "minimum": 0,
      "description": "Count of critical issues resolved"
    },
    "shipping_streak_days": {
      "type": "number",
      "minimum": 0,
      "description": "Consecutive days with commits"
    },
    "tweetable": {
      "type": "string",
      "description": "One-liner summary for announcement"
    }
  },
  "additionalProperties": false
}
