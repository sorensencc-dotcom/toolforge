{
  "name": "toolforge-marketplace",
  "version": "1.0.0",
  "type": "module",
  "description": "Toolforge Marketplace: API + UI for skill discovery and installation",
  "main": "src/api/server.js",
  "scripts": {
    "migrate": "node src/db/migrate.js",
    "trending:refresh": "node src/services/trending-batch.js",
    "trending:schedule": "pwsh src/services/trending-scheduler.ps1",
    "trending:unschedule": "pwsh src/services/trending-scheduler.ps1 -Unregister",
    "e2e": "node src/e2e/harness.js",
    "load:marketplace": "node src/load-tests/marketplace-load.js",
    "migrate:reset": "psql $DATABASE_URL -c 'DROP SCHEMA public CASCADE; CREATE SCHEMA public;' && npm run migrate",
    "api:dev": "node --watch src/api/server.js",
    "api:build": "echo 'ESM, no build needed'",
    "ui:dev": "vite src/ui",
    "ui:build": "vite build src/ui",
    "ui:preview": "vite preview src/ui",
    "ui:test": "vitest run",
    "test": "node --test src/**/*.test.js",
    "test:watch": "node --test --watch src/**/*.test.js",
    "lint": "eslint src/**/*.js",
    "stress:gate04": "node src/stress-tests/gate04-fairness.js",
    "dev": "npm run api:dev"
  },
  "keywords": [
    "toolforge",
    "marketplace",
    "skills",
    "discovery"
  ],
  "author": "CIC Team",
  "license": "MIT",
  "bin": {
    "toolforge": "src/cli/index.js"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.52.0",
    "jsdom": "^24.1.3",
    "nodemon": "^3.0.1",
    "vite": "^5.0.8",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
