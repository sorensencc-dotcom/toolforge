{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Vision Subsystem Lineage Log",
  "type": "object",
  "additionalProperties": false,
  "required": ["entries"],
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "artifact_version", "operation", "actor", "timestamp", "status"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^OP-\\d{4}$",
            "description": "Operation ID: OP-0001, OP-0002, ..."
          },
          "artifact_version": {
            "type": "string",
            "pattern": "^v\\d{3}$"
          },
          "operation": {
            "type": "string",
            "enum": ["CREATE", "UPDATE", "RATIFY", "ACTIVATE"]
          },
          "actor": {
            "type": "string",
            "pattern": "^ACTOR-\\d{3}$"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "ratified", "active"]
          },
          "reason": {
            "type": ["string", "null"]
          }
        }
      }
    }
  }
}
