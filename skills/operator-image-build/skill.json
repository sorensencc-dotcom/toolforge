{
  "id": "operator-image-build",
  "name": "Operator Image Build",
  "version": "1.0.0",
  "description": "Deterministic Docker image build, tag, push, and verification for harness-v3 and onnx-sidecar. Sealed layer hashes, registry validation, node-local air-gapped import support.",
  "category": "pipeline",
  "metadata": {
    "runtime": "node",
    "entrypoint": "src/index.ts",
    "timeout_ms": 600000,
    "memory_mb": 1024
  },
  "inputs": {
    "required": [],
    "optional": {
      "action": {
        "type": "string",
        "enum": [
          "build",
          "tag",
          "push",
          "verify",
          "import",
          "all"
        ],
        "default": "all",
        "description": "Action to perform: build|tag|push|verify|import|all"
      },
      "registry": {
        "type": "string",
        "default": "registry.internal:5000",
        "description": "Docker registry URL"
      },
      "workdir": {
        "type": "string",
        "default": ".",
        "description": "Working directory containing harness-v3/ and onnx-sidecar/ subdirs"
      },
      "dryRun": {
        "type": "boolean",
        "default": false,
        "description": "Log commands without executing"
      },
      "verbose": {
        "type": "boolean",
        "default": true,
        "description": "Log detailed output"
      }
    }
  },
  "outputs": {
    "success": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "ok"
          ]
        },
        "message": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string"
            },
            "images": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "registry": {
              "type": "string"
            },
            "duration_ms": {
              "type": "number"
            }
          }
        }
      }
    },
    "error": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "error"
          ]
        },
        "message": {
          "type": "string"
        },
        "data": {
          "type": "null"
        }
      }
    }
  },
  "permissions": {
    "required": [
      "filesystem:read",
      "filesystem:write",
      "exec:docker"
    ]
  },
  "runtime": "node",
  "entrypoint": "src/index.ts",
  "integrations": {
    "cowork": {
      "registered": false,
      "pluginType": "skill",
      "icon": "zap",
      "registrationPath": "cowork://toolforge/skills/operator-image-build",
      "status": "pending_registration"
    }
  },
  "tooltip": "Deterministic Docker image build, tag, push, and verification for harness-v3 and onnx-sidecar. Sealed layer hashes, registry validation, node-local air-gapped import support."
}
