{
  "id": "work-summarizer",
  "name": "Work Summarizer v4.0",
  "version": "4.0.0",
  "description": "Daily/weekly dev work summaries with pluggable reasoning providers (Claude, Ollama). Repo scans, transcript analysis, subsystem/cross-repo impact inference, operator-grade synthesis. Fallback to deterministic mode if LLM unavailable.",
  "category": "observability",
  "metadata": {
    "runtime": "node",
    "entrypoint": "src/index.ts",
    "timeout_ms": 120000,
    "memory_mb": 512
  },
  "inputs": {
    "optional": {
      "mode": {
        "type": "string",
        "enum": [
          "daily",
          "weekly"
        ],
        "default": "daily",
        "description": "Report window: daily (24h) or weekly (7d)"
      },
      "registryPath": {
        "type": "string",
        "default": "C:\\dev\\repo-registry.json",
        "description": "Path to repo registry JSON (repos.repos array)"
      },
      "transcriptsRoot": {
        "type": "string",
        "default": "C:\\Users\\soren\\.claude\\projects",
        "description": "Root directory for Claude Code session transcripts"
      },
      "outputDir": {
        "type": "string",
        "default": "C:\\dev\\CIP\\CIC\\logs\\work-summaries",
        "description": "Directory for output JSON/TXT reports"
      },
      "queueDir": {
        "type": "string",
        "default": "C:\\dev\\CIP\\CIC\\ingestion\\queue",
        "description": "Optional: CIC ingestion queue directory for routing artifacts"
      },
      "includeRoutingArtifact": {
        "type": "boolean",
        "default": false,
        "description": "Write MAAL routing artifact to queueDir"
      },
      "reasoningEnabled": {
        "type": "boolean",
        "default": false,
        "description": "Enable LLM reasoning synthesis (requires provider env vars)"
      },
      "reasoningProvider": {
        "type": "string",
        "enum": [
          "claude",
          "ollama"
        ],
        "default": "claude",
        "description": "Reasoning provider: 'claude' (Anthropic) or 'ollama' (local)"
      },
      "anthropicModel": {
        "type": "string",
        "default": "claude-haiku-4-5-20251001",
        "description": "Anthropic model to use for reasoning synthesis"
      },
      "reasoningTimeoutMs": {
        "type": "number",
        "default": 30000,
        "description": "Per-subsystem reasoning call timeout in milliseconds"
      }
    }
  },
  "outputs": {
    "success": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "ok"
          ]
        },
        "message": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "properties": {
            "schema_version": {
              "type": "string"
            },
            "period": {
              "type": "string",
              "enum": [
                "daily",
                "weekly"
              ]
            },
            "window_start": {
              "type": "string",
              "format": "date-time"
            },
            "window_end": {
              "type": "string",
              "format": "date-time"
            },
            "generated_at": {
              "type": "string",
              "format": "date-time"
            },
            "repos_scanned": {
              "type": "integer"
            },
            "repos_skipped_missing": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "modified_files": {
              "type": "integer"
            },
            "transcript_sessions_scanned": {
              "type": "integer"
            },
            "transcript_files_touched": {
              "type": "integer"
            },
            "work_by_category": {
              "type": "object"
            },
            "drift_signals": {
              "type": "object"
            },
            "repo_deltas": {
              "type": "array"
            },
            "subsystem_impacts": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "cross_repo_impacts": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "transcript_excerpts": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "notable_changes": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "risks_or_followups": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "message": {
              "type": "string"
            }
          }
        }
      }
    },
    "error": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "error"
          ]
        },
        "message": {
          "type": "string"
        },
        "data": {
          "type": "null"
        }
      }
    }
  },
  "permissions": {
    "required": [
      "filesystem:read",
      "filesystem:write"
    ]
  },
  "runtime": "node",
  "entrypoint": "src/index.ts",
  "integrations": {
    "cowork": {
      "registered": false,
      "pluginType": "skill",
      "icon": "zap",
      "registrationPath": "cowork://toolforge/skills/work-summarizer",
      "status": "pending_registration"
    }
  },
  "tooltip": "Daily/weekly dev work summaries with pluggable reasoning providers (Claude, Ollama). Repo scans, transcript analysis, subsystem/cross-repo impact inference, operator-grade synthesis. Fallback to deterministic mode if LLM unavailable."
}
