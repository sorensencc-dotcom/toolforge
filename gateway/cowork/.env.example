# Cowork Gateway Environment Variables
# Copy this file to .env and configure for local development

# Mock Cowork server URL (no real external API exists yet — see docs/meta/phase-3-scope-charter.md)
COWORK_API_URL=http://127.0.0.1:4790

# Gateway API key (must match the key used by the mock server)
# Format: alphanumeric + hyphens, 20+ chars
COWORK_API_KEY=mock-api-key-1234567890ab

# Gateway identifier (unique per installation)
COWORK_GATEWAY_ID=toolforge-gateway

# Sync interval in seconds (optional, default: 300)
COWORK_SYNC_INTERVAL=300

# Path to toolforge skills directory (for skill discovery)
TOOLFORGE_SKILLS_PATH=../../skills
