{
  "name": "toolforge-cowork-gateway",
  "version": "1.0.0",
  "description": "Cowork plugin registration gateway for Toolforge skill network",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "gateway:init": "ts-node src/index.ts",
    "gateway:status": "ts-node src/utils/status.ts",
    "sync:pull": "ts-node src/cli/sync.ts pull",
    "sync:push": "ts-node src/cli/sync.ts push",
    "sync:audit": "ts-node src/cli/sync.ts audit",
    "sync:rollback": "ts-node src/cli/rollback.ts",
    "audit:log": "ts-node src/cli/audit-log.ts",
    "mock:server": "ts-node mock-server/bin/start.ts",
    "load:test:1x": "ts-node load-test/runner.ts --multiplier 1 --duration 60",
    "load:test:10x": "ts-node load-test/runner.ts --multiplier 10 --duration 120",
    "load:test:100x": "ts-node load-test/runner.ts --multiplier 100 --duration 180",
    "load:test:500x": "ts-node load-test/runner.ts --multiplier 500 --duration 300",
    "lint": "eslint src tests",
    "clean": "rm -rf dist"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "express": "^4.18.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "toolforge",
    "cowork",
    "gateway",
    "skills",
    "registration",
    "sync"
  ],
  "author": "Rewrite Labs",
  "license": "MIT"
}
